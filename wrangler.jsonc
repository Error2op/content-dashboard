{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "content-dashboard",
	"compatibility_date": "2026-06-30",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"main": ".open-next/worker.js",
	"assets": {
		"directory": ".open-next/cloudflare",
		"binding": "ASSETS"
	}
}