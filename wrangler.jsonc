{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "content-dashboard",
	"compatibility_date": "2026-06-30",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"main": ".open-next/worker.js",
	"assets": ".open-next/cloudflare",
	"d1_databases": [
		{
			"binding": "TURSO_DATABASE",
			"database_name": "content-dashboard-db",
			"database_id": "af6e0e1df24c966076169fca50cb29e8"
		}
	],
	"vars": {
		"NODE_VERSION": "22"
	}
}